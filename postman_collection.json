{
  "info": {
    "name": "DGR Platform Local API",
    "_postman_id": "dgr-platform-local",
    "description": "Local testing collection for DGR Platform microservices on localhost ports 3000-3005.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth Service (3001)",
      "item": [
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@sepcpower.com\",\n  \"password\": \"Admin@1234\"\n}"
            },
            "url": {
              "raw": "http://localhost:3001/api/auth/login",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3001",
              "path": ["api", "auth", "login"]
            }
          }
        },
        {
          "name": "Me (current user)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:3001/api/auth/me",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3001",
              "path": ["api", "auth", "me"]
            }
          }
        }
      ]
    },
    {
      "name": "Plant Config Service (3002)",
      "item": [
        {
          "name": "List Plants",
          "request": {
            "method": "GET",
            "url": {
              "raw": "http://localhost:3002/api/plants",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3002",
              "path": ["api", "plants"]
            }
          }
        },
        {
          "name": "Submission Status by Date",
          "request": {
            "method": "GET",
            "url": {
              "raw": "http://localhost:3002/api/plants/{{plantId}}/submission-status?date={{date}}",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3002",
              "path": ["api", "plants", "{{plantId}}", "submission-status"],
              "query": [{ "key": "date", "value": "{{date}}" }]
            }
          }
        }
      ]
    },
