# ═══════════════════════════════════════════════════
#  DGR PLATFORM — Environment Variables
#  Copy this to .env and fill in values
# ═══════════════════════════════════════════════════

# ── PostgreSQL ──
DB_HOST=localhost
DB_PORT=5432
DB_NAME=dgr_platform
DB_USER=dgr_user
DB_PASSWORD=your_secure_password_here
DB_POOL_MIN=2
DB_POOL_MAX=10

# ── JWT ──
JWT_SECRET=your_jwt_secret_minimum_64_chars_here_change_this
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ── Service Ports ──
GATEWAY_PORT=3000
AUTH_SERVICE_PORT=3001
PLANT_CONFIG_SERVICE_PORT=3002
DATA_ENTRY_SERVICE_PORT=3003
DGR_COMPUTE_SERVICE_PORT=3004
REPORT_EXPORT_SERVICE_PORT=3005

# ── Internal Service URLs (used by gateway & inter-service calls) ──
AUTH_SERVICE_URL=http://localhost:3001
PLANT_CONFIG_SERVICE_URL=http://localhost:3002
DATA_ENTRY_SERVICE_URL=http://localhost:3003
DGR_COMPUTE_SERVICE_URL=http://localhost:3004
REPORT_EXPORT_SERVICE_URL=http://localhost:3005

# ── App ──
NODE_ENV=development
LOG_LEVEL=debug
CORS_ORIGIN=http://localhost:5173

# ── Email Alerts ──
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=alerts@sepcpower.com
SMTP_PASS=your_smtp_password
ALERT_FROM=DGR Portal <alerts@sepcpower.com>

# ── Redis (optional — for session caching) ──
REDIS_URL=redis://localhost:6379
